# Opsight environment template
#
# This file is a local/developer-safe example only.
# Do not put real production secrets in this file.
# Production values should be stored in GitHub secrets/variables and
# Azure runtime configuration.

# Required in all environments
APP_ENV=dev
APP_VERSION=1.0.0
PORT=8000
# Dataset access code checked by protected API routes.
UPLOAD_ACCESS_CODE=replace-me
PERSISTENCE_MODE=json
STORAGE_PATH=data/records.json
LOG_LEVEL=INFO
ALLOW_LOCAL_FALLBACK=true
PIPELINE_SUMMARY_PATH=reports/pipeline_run_summary.json

# Required only when APP_ENV=prod
# In production, Blob is the mandatory ingestion source.
BLOB_ACCOUNT=
BLOB_CONTAINER=
BLOB_PATH=

# Optional runtime values
# Used by API callers and Streamlit UI. If omitted for Streamlit,
# it falls back to http://127.0.0.1:8000.
API_BASE_URL=http://127.0.0.1:8000
ENABLE_PIPELINE=true
INPUT_SOURCE_PATH=data/opsight_sample_sales.csv
# Comma-separated browser origins allowed to call the API directly.
# Example: http://localhost:5173,https://your-ui.example.com
CORS_ALLOWED_ORIGINS=

# Optional logging extras
LOG_TO_FILE=false
LOG_FILE=logs/pipeline_run.log

# Optional integrations
# If a connection string is used in production, store it as a secret
# in GitHub/Azure rather than committing a value here.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AZURE_KEY_VAULT_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Optional local SQL Server startup configuration used by POST /sql/start
# Default behavior: attempts to start Docker service "opsight-sqlserver"
SQL_CONNECTION_STRING=mssql+pyodbc://sa:OpsightDev%2123456@127.0.0.1:1433/master?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
SQL_SERVER_PORT=1433
SQL_SA_PASSWORD=OpsightDev!23456
# Optional override command (Windows example):
# SQL_START_COMMAND=docker compose up -d opsight-sqlserver