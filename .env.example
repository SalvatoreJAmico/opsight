# Required
APP_ENV=dev
APP_VERSION=1.0.0
PORT=8000
UPLOAD_ACCESS_CODE=replace-me
PERSISTENCE_MODE=json
STORAGE_PATH=data/records.json
LOG_LEVEL=INFO
ALLOW_LOCAL_FALLBACK=true

# Required only in prod
BLOB_ACCOUNT=
BLOB_CONTAINER=

# Optional
BLOB_PATH=
API_BASE_URL=http://127.0.0.1:8000
ENABLE_PIPELINE=true
INPUT_SOURCE_PATH=data/opsight_sample_sales.csv
PIPELINE_SUMMARY_PATH=reports/pipeline_run_summary.json

# Optional logging extras
LOG_TO_FILE=false
LOG_FILE=logs/pipeline_run.log

# Optional integrations
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AZURE_KEY_VAULT_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=