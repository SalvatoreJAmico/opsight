# Frontend environment variables
#
# Dev mode (npm run dev):
# - UI uses Vite proxy routes /api-local and /api-cloud
# - Set proxy targets below if your local/deployed API endpoints differ
#
# Production build (npm run build):
# - UI uses real URLs
# - Set VITE_LOCAL_API_URL and VITE_CLOUD_API_URL as needed
# - Optional single-target fallback uses VITE_API_BASE_URL

# Optional single-target fallback for components without target selection.
# Default in production: deployed cloud API URL.
# VITE_API_BASE_URL=https://opsight-api.calmstone-581ea79a.eastus.azurecontainerapps.io

# Dev proxy target for "cloud" API requests.
# Default: deployed cloud API URL.
# VITE_API_PROXY_TARGET=https://opsight-api.calmstone-581ea79a.eastus.azurecontainerapps.io

# Dev proxy target for "local" API requests.
# Default: http://127.0.0.1:8000
# VITE_API_PROXY_TARGET_LOCAL=http://127.0.0.1:8000

# Production-only explicit URLs used by resolveBaseUrl().
# VITE_LOCAL_API_URL=http://127.0.0.1:8000
# VITE_CLOUD_API_URL=https://opsight-api.calmstone-581ea79a.eastus.azurecontainerapps.io

# Legacy alias retained for compatibility with older setup notes.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# GitHub Actions / Azure Static Web Apps deployment:
# - store the deploy token in GitHub secret AZURE_STATIC_WEB_APPS_API_TOKEN
# - store production frontend URLs in GitHub repository variables
# - prefer VITE_CLOUD_API_URL for the deployed API origin
# - optionally set VITE_API_BASE_URL when the UI should use a single production target