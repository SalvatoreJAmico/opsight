# Opsight production template
#
# This file documents the non-secret production contract.
# Keep placeholders only. Real secret values belong in Azure secrets and/or
# GitHub Actions secrets, not in source control.

# Required runtime values
APP_ENV=prod
APP_VERSION=1.0.0
PORT=8000
UPLOAD_ACCESS_CODE=replace-me
PERSISTENCE_MODE=json
STORAGE_PATH=data/records.json
LOG_LEVEL=INFO
ALLOW_LOCAL_FALLBACK=false
PIPELINE_SUMMARY_PATH=reports/pipeline_run_summary.json

# Required Blob ingestion values in production
BLOB_ACCOUNT=
BLOB_CONTAINER=
BLOB_PATH=

# Optional runtime values
API_BASE_URL=http://127.0.0.1:8000
ENABLE_PIPELINE=true
INPUT_SOURCE_PATH=data/opsight_sample_sales.csv
# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=

# Optional logging values
LOG_TO_FILE=false
LOG_FILE=logs/pipeline_run.log

# Optional integration values
# Store secret values outside the repository.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AZURE_KEY_VAULT_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=